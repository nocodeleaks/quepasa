{{ define "content" }}
<style>
  .landing-page {
    min-height: 100vh;
    background: var(--qp-bg);
  }
</style>

<section class="hero is-fullheight landing-page">
  <div class="hero-body">
    <div class="container has-text-centered">
      <figure class="image is-96x96 is-inline-block mb-4">
        <img src="/assets/favicon.png" alt="QuePasa logo">
      </figure>
      <h1 class="title is-2">QuePasa</h1>
      <p class="subtitle has-text-grey">WhatsApp bot management console</p>
      <a class="button is-primary is-medium mt-4" href="/login">
        <span class="icon"><i class="fas fa-sign-in-alt"></i></span>
        <span>Sign In</span>
      </a>
    </div>
  </div>
</section>
{{ end }}
