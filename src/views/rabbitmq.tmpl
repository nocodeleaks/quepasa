{{ define "content" }}
  <style>
    .page-header {
      padding: 1.5rem 1.5rem 0.5rem;
      border-bottom: 1px solid var(--qp-border-soft);
      margin-bottom: 1.5rem;
      display: flex;
      align-items: center;
      justify-content: space-between;
      flex-wrap: wrap;
      gap: 0.75rem;
    }
    .page-header-left { display: flex; flex-direction: column; }
    .page-header-actions { display: flex; gap: 0.5rem; align-items: center; }
    .table-container { padding: 0 1.5rem 1.5rem; }
    .table thead th { background: var(--qp-thead-bg); color: var(--qp-thead-text); font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.05em; border-bottom: 2px solid var(--qp-thead-border) !important; }
    .table td { vertical-align: middle; }

    /* ── Modal ──────────────────────────────────────────── */
    .modal-card { border-radius: 12px; overflow: hidden; box-shadow: 0 8px 40px var(--qp-shadow-lg); }
    .modal-head-brand {
      background: linear-gradient(135deg, #7C3AED 0%, #5B21B6 100%);
      border-bottom: none !important;
      padding: 1rem 1.25rem;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }
    .modal-head-brand .modal-card-title {
      color: #fff;
      font-size: 1rem;
      font-weight: 700;
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }
    .modal-head-brand .modal-close-btn {
      width: 28px; height: 28px;
      border-radius: 50%;
      background: rgba(255,255,255,0.22);
      border: none;
      cursor: pointer;
      display: flex; align-items: center; justify-content: center;
      color: #fff;
      font-size: 0.85rem;
      flex-shrink: 0;
      transition: background 0.15s;
    }
    .modal-head-brand .modal-close-btn:hover { background: rgba(255,255,255,0.38); }
    .modal-card-body { padding: 1.25rem 1.5rem; }
    .modal-card-foot {
      background: var(--qp-surface-alt);
      border-top: 1px solid var(--qp-border) !important;
      padding: 0.85rem 1.5rem;
      display: flex;
      gap: 0.5rem;
    }
    .modal-section-label {
      display: flex;
      align-items: center;
      gap: 0.35rem;
      font-weight: 700;
      font-size: 0.72rem;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      color: var(--qp-text-light);
      margin-bottom: 0.6rem;
    }
    .page-alert { padding: 0 1.5rem; }
    .page-icon { color: var(--qp-primary); }
    .required-mark { color: var(--qp-danger-solid); }
    .mono-field { font-family: monospace; font-size: 0.82rem; }
    .mono-field-compact { font-family: monospace; font-size: 0.78rem; }
    .mono-input { font-family: monospace; font-size: 0.85rem; }
    .readonly-field {
      background: var(--qp-surface-accent) !important;
      color: var(--qp-primary-dark) !important;
      font-family: monospace;
      font-size: 0.78rem;
    }
    /* RabbitMQ info box */
    .rmq-info {
      border-radius: 8px;
      background: var(--qp-primary-light);
      border: 1px solid var(--qp-primary-border);
      padding: 0.85rem 1rem;
      margin-bottom: 1.25rem;
    }
    .rmq-info-title {
      font-weight: 700;
      color: var(--qp-primary-dark);
      font-size: 0.88rem;
      margin-bottom: 0.5rem;
      display: flex;
      align-items: center;
      gap: 0.4rem;
    }
    .rmq-info code {
      background: var(--qp-primary-mid);
      color: var(--qp-primary-dark);
      padding: 1px 6px;
      border-radius: 4px;
      font-size: 0.78rem;
      border: 1px solid var(--qp-primary-border);
    }
    .rmq-info-queue-list {
      list-style: none;
      margin: 0.35rem 0 0.35rem 0.25rem;
      padding: 0;
      display: flex;
      flex-direction: column;
      gap: 0.2rem;
      font-size: 0.81rem;
      color: var(--qp-primary-dark);
    }
    .rmq-info-queue-list li { display: flex; align-items: baseline; gap: 0.5rem; }
    .rmq-info-note {
      font-size: 0.77rem;
      color: var(--qp-primary);
      font-style: italic;
      margin-top: 0.4rem;
    }
    .rmq-info-line {
      font-size: 0.82rem;
      color: var(--qp-primary-dark);
      margin-bottom: 0.3rem;
    }
    .rmq-info-subtitle {
      font-size: 0.8rem;
      color: var(--qp-primary);
      margin-bottom: 0.2rem;
    }
    .rmq-info-queue-note {
      color: var(--qp-text-muted);
    }
    /* Checkbox grid */
    .check-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 0.4rem;
    }
    .check-item {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      padding: 0.4rem 0.65rem;
      border: 1px solid var(--qp-border);
      border-radius: 6px;
      cursor: pointer;
      font-size: 0.83rem;
      color: var(--qp-text);
      transition: background 0.12s, border-color 0.12s;
      user-select: none;
    }
    .check-item:hover { background: var(--qp-primary-light); border-color: var(--qp-primary-border); }
    .check-item input[type=checkbox] { margin: 0; accent-color: #7C3AED; width: 14px; height: 14px; flex-shrink: 0; }
    .check-item .check-icon { color: var(--qp-primary); font-size: 0.75rem; width: 14px; text-align: center; flex-shrink: 0; }
  </style>

  {{ if .ErrorMessage }}
  <div class="page-alert">
    <div class="notification is-warning is-light">
      <span class="icon"><i class="fas fa-exclamation-triangle"></i></span>
      {{ .ErrorMessage }}
    </div>
  </div>
  {{ end }}

  <div class="page-header">
    <div class="page-header-left">
      <h1 class="title is-3 mb-0">
        <span class="icon-text">
          <span class="icon page-icon"><i class="fas fa-exchange-alt"></i></span>
          <span>RabbitMQ Configurations</span>
        </span>
      </h1>
      <p class="subtitle is-6 has-text-grey mt-1">
        <span class="tag is-light mr-1">{{ len .RabbitMQ }}</span> configured for <b>{{ .Server.Wid }}</b>
      </p>
    </div>
    <div class="page-header-actions">
      <button class="button is-primary" onclick="showAddRabbitMQModal()">
        <span class="icon is-small"><i class="fa fa-plus"></i></span>
        <span>Add RabbitMQ Configuration</span>
      </button>
      <a class="button is-light" href="/form/account">
        <span class="icon is-small"><i class="fas fa-arrow-left"></i></span>
        <span>Back</span>
      </a>
    </div>
  </div>

  <!-- RabbitMQ Configurations Table -->
  <div class="table-container">
    <table class="table is-fullwidth is-hoverable">
      <thead>
        <tr>
          <th>Connection String</th>
          <th>Track ID</th>
          <th style="text-align: center;">Settings</th>
          <th style="width: 4rem;">Extra</th>
          <th style="width: 4rem;">Status</th>
          <th style="width: 4rem;">Actions</th>
        </tr>
      </thead>
      <tbody>
        {{ range .RabbitMQ }}   
          <tr>
            <td><small><code title="Connection String">{{ .ConnectionString }}</code></small></td>
            <td><span>{{ .TrackId }}</span></td>
            <td style="text-align: center;">
              <div style="text-align: center; display: flex; justify-content: center;">          
                <p class="control"> 
                  <form class="" method="post" action="/form/toggle?token={{ $.Server.Token }}&key=rabbitmq-forwardinternal" data-value="{{ .ForwardInternal }}">
                    <input name="connection_string" type="hidden" value="{{ .ConnectionString }}" />
                    <button class="button {{ if .ForwardInternal }}is-info{{ else }}is-danger{{ end }}" title="ForwardInternal: {{ .ForwardInternal }}">
                      <span class="icon is-small is-inline"><i class="fa fa-forward"></i></span>
                    </button>
                  </form>
                </p>
                <p>&nbsp;</p>
                <p class="control"> 
                  <form class="" method="post" action="/form/toggle?token={{ $.Server.Token }}&key=rabbitmq-broadcasts" data-value="{{ .Broadcasts }}">
                    <input name="connection_string" type="hidden" value="{{ .ConnectionString }}">
                    <button class="button {{ if .IsSetBroadcasts }}{{ if .GetBroadcasts }}is-info is-hovered{{ else }}is-danger is-hovered{{ end }}{{ end }}" title="Broadcasts: {{ .Broadcasts }}">
                      <span class="icon is-small is-inline"><i class="fa fa-bullhorn"></i></span>
                    </button>
                  </form>
                </p>
                <p class="control"> 
                  <form class="" method="post" action="/form/toggle?token={{ $.Server.Token }}&key=rabbitmq-groups" data-value="{{ .Groups }}">
                    <input name="connection_string" type="hidden" value="{{ .ConnectionString }}">
                    <button class="button {{ if .IsSetGroups }}{{ if .GetGroups }}is-info is-hovered{{ else }}is-danger is-hovered{{ end }}{{ end }}" title="Groups: {{ .Groups }}">
                      <span class="icon is-small is-inline"><i class="fa fa-users"></i></span>
                    </button>
                  </form>
                </p>
                <p class="control"> 
                  <form class="" method="post" action="/form/toggle?token={{ $.Server.Token }}&key=rabbitmq-direct" data-value="{{ .Direct }}">
                    <input name="connection_string" type="hidden" value="{{ .ConnectionString }}">
                    <button class="button {{ if .IsSetDirect }}{{ if .GetDirect }}is-info is-hovered{{ else }}is-danger is-hovered{{ end }}{{ end }}" title="Direct: {{ .Direct }}">
                      <span class="icon is-small is-inline"><i class="fa fa-comment"></i></span>
                    </button>
                  </form>
                </p>
                <p class="control"> 
                  <form class="" method="post" action="/form/toggle?token={{ $.Server.Token }}&key=rabbitmq-readreceipts" data-value="{{ .ReadReceipts }}">
                    <input name="connection_string" type="hidden" value="{{ .ConnectionString }}">
                    <button class="button {{ if .IsSetReadReceipts }}{{ if .GetReadReceipts }}is-info is-hovered{{ else }}is-danger is-hovered{{ end }}{{ end }}" title="ReadReceipts: {{ .ReadReceipts }}">
                      <span class="icon is-small is-inline"><i class="fa fa-check-double"></i></span>
                    </button>
                  </form>
                </p>
                <p class="control"> 
                  <form class="" method="post" action="/form/toggle?token={{ $.Server.Token }}&key=rabbitmq-calls" data-value="{{ .Calls }}">
                    <input name="connection_string" type="hidden" value="{{ .ConnectionString }}">
                    <button class="button {{ if .IsSetCalls }}{{ if .GetCalls }}is-info is-hovered{{ else }}is-danger is-hovered{{ end }}{{ end }}" title="Calls: {{ .Calls }}">
                      <span class="icon is-small is-inline"><i class="fa fa-phone"></i></span>
                    </button>
                  </form>
                </p>
              </div>
            </td>
            <td>
              {{ if .IsSetExtra }}
                <button class="button is-info" onclick="showExtraModal('{{ .ConnectionString }}', 'rabbitmq', `{{ .GetExtraText }}`)" title="Extra Data Available">
                  <span class="icon is-small is-inline"><i class="fa fa-plus"></i></span>
                </button>
              {{ else }}
                <button class="button is-light" onclick="showExtraModal('{{ .ConnectionString }}', 'rabbitmq', null)" title="Add Extra Data">
                  <span class="icon is-small is-inline"><i class="fa fa-plus"></i></span>
                </button>
              {{ end }}
            </td>
            <td>
              {{ if .IsFailureMoreRecent }}
                <button class="button is-danger is-outlined" title="Last Failure: {{ .Failure }}">
                  <span class="icon is-small is-inline"><i class="fa fa-exclamation-triangle"></i></span>
                </button>
              {{ else if .HasRecentSuccess }}
                <button class="button is-success is-outlined" title="Last Success: {{ .Success }}">
                  <span class="icon is-small is-inline"><i class="fa fa-check"></i></span>
                </button>
              {{ else if .Failure }}
                <button class="button is-danger is-outlined" title="Last Failure: {{ .Failure }}">
                  <span class="icon is-small is-inline"><i class="fa fa-exclamation-triangle"></i></span>
                </button>
              {{ else if .Success }}
                <button class="button is-success is-outlined" title="Last Success: {{ .Success }}">
                  <span class="icon is-small is-inline"><i class="fa fa-check"></i></span>
                </button>
              {{ else }}
                <button class="button is-light" title="Not tested yet">
                  <span class="icon is-small is-inline"><i class="fa fa-clock"></i></span>
                </button>
              {{ end }}
            </td>
            <td>
              <form class="" method="post" action="/form/delete?token={{ $.Server.Token }}&key=rabbitmq">
                <input name="connection_string" type="hidden" value="{{ .ConnectionString }}">
                <button class="button is-danger is-outlined" title="Delete this RabbitMQ configuration">
                  <i class="fa fa-trash"></i>&nbsp;&nbsp;
                  Delete
                </button>
              </form>
            </td>
          </tr>       
        {{ end }}
      </tbody>
    </table>
  </div>

  <!-- Modal: Add RabbitMQ -->
  <div class="modal" id="addRabbitMQModal">
    <div class="modal-background" onclick="closeAddRabbitMQModal()"></div>
    <div class="modal-card">
      <header class="modal-card-head modal-head-brand">
        <p class="modal-card-title">
          <span class="icon"><i class="fas fa-exchange-alt"></i></span>
          Add RabbitMQ Configuration
        </p>
        <button class="modal-close-btn" aria-label="close" onclick="closeAddRabbitMQModal()">
          <i class="fas fa-times"></i>
        </button>
      </header>
      <section class="modal-card-body">

        <!-- Routing info -->
        <div class="rmq-info">
          <div class="rmq-info-title">
            <i class="fas fa-project-diagram"></i>
            QuePasa RabbitMQ Routing System
          </div>
          <div class="rmq-info-line">
            <strong>Exchange:</strong> <code>quepasa.exchange</code>
          </div>
          <div class="rmq-info-subtitle"><strong>Queues:</strong></div>
          <ul class="rmq-info-queue-list">
            <li><code>quepasa.production</code><span class="rmq-info-queue-note">— normal chat messages</span></li>
            <li><code>quepasa.history</code><span class="rmq-info-queue-note">— history sync</span></li>
            <li><code>quepasa.other</code><span class="rmq-info-queue-note">— system events, calls, contacts</span></li>
          </ul>
          <p class="rmq-info-note">All bots share the same Exchange and Queues. Only the connection string is per bot.</p>
        </div>

        <div class="field mb-4">
          <label class="label is-small">Connection String <span class="required-mark">*</span></label>
          <div class="control has-icons-left">
            <input class="input mono-input" type="text" id="newConnectionString"
              placeholder="amqp://username:password@host:port/vhost" required
              >
            <span class="icon is-small is-left has-text-grey-light"><i class="fas fa-plug"></i></span>
          </div>
          <p class="help">
            Example: <code>amqp://admin:password@rabbitmq.example.com:5672/%2F</code>
          </p>
        </div>

        <div class="field mb-4">
          <label class="label is-small">Track ID</label>
          <div class="control has-icons-left">
            <input class="input" type="text" id="newTrackId" placeholder="Optional tracking identifier">
            <span class="icon is-small is-left has-text-grey-light"><i class="fas fa-tag"></i></span>
          </div>
        </div>

        <div class="field mb-4">
          <p class="modal-section-label">
            <span class="icon is-small"><i class="fas fa-sliders-h"></i></span>
            <span>Configuration</span>
          </p>
          <div class="check-grid">
            <label class="check-item">
              <input type="checkbox" id="newForwardInternal">
              <span class="check-icon"><i class="fas fa-forward"></i></span>
              Forward Internal
            </label>
            <label class="check-item">
              <input type="checkbox" id="newBroadcasts">
              <span class="check-icon"><i class="fas fa-bullhorn"></i></span>
              Broadcasts
            </label>
            <label class="check-item">
              <input type="checkbox" id="newGroups">
              <span class="check-icon"><i class="fas fa-users"></i></span>
              Group Messages
            </label>
            <label class="check-item">
              <input type="checkbox" id="newDirect">
              <span class="check-icon"><i class="fas fa-comment"></i></span>
              Direct Messages
            </label>
            <label class="check-item">
              <input type="checkbox" id="newReadReceipts">
              <span class="check-icon"><i class="fas fa-check-double"></i></span>
              Read Receipts
            </label>
            <label class="check-item">
              <input type="checkbox" id="newCalls">
              <span class="check-icon"><i class="fas fa-phone"></i></span>
              Call Events
            </label>
          </div>
        </div>

        <div class="field">
          <p class="modal-section-label">
            <span class="icon is-small"><i class="fas fa-code"></i></span>
            <span>Extra Data (JSON)</span>
          </p>
          <div class="control">
            <textarea class="textarea is-small mono-field" id="newExtra" rows="4"
              placeholder='{"api_key": "secret", "timeout": 30}'></textarea>
          </div>
          <p class="help">Optional JSON forwarded with every RabbitMQ message</p>
        </div>

      </section>
      <footer class="modal-card-foot">
        <button class="button is-primary" onclick="saveNewRabbitMQ()">
          <span class="icon is-small"><i class="fas fa-plus-circle"></i></span>
          <span>Add Configuration</span>
        </button>
        <button class="button is-light" onclick="closeAddRabbitMQModal()">Cancel</button>
      </footer>
    </div>
  </div>

  <!-- Modal: Edit Extra -->
  <div class="modal" id="extraModal">
    <div class="modal-background" onclick="closeExtraModal()"></div>
    <div class="modal-card">
      <header class="modal-card-head modal-head-brand">
        <p class="modal-card-title">
          <span class="icon"><i class="fas fa-cog"></i></span>
          Extra Field
        </p>
        <button class="modal-close-btn" aria-label="close" onclick="closeExtraModal()">
          <i class="fas fa-times"></i>
        </button>
      </header>
      <section class="modal-card-body">

        <div class="field mb-4">
          <label class="label is-small">Connection String</label>
          <div class="control has-icons-left">
            <input class="input readonly-field" type="text" id="extraConnectionString" readonly>
            <span class="icon is-small is-left has-text-grey-light"><i class="fas fa-plug"></i></span>
          </div>
        </div>

        <div class="field">
          <p class="modal-section-label">
            <span class="icon is-small"><i class="fas fa-code"></i></span>
            <span>Extra Data (JSON)</span>
          </p>
          <div class="control">
            <textarea class="textarea mono-field" id="extraData" rows="8"
              placeholder='{"exemplo": "valor", "outro_campo": 123}'></textarea>
          </div>
          <p class="help">Leave empty to remove extra data</p>
        </div>

      </section>
      <footer class="modal-card-foot">
        <button class="button is-primary" onclick="saveExtra()">
          <span class="icon is-small"><i class="fas fa-save"></i></span>
          <span>Save</span>
        </button>
        <button class="button is-light" onclick="closeExtraModal()">Cancel</button>
      </footer>
    </div>
  </div>

  <script>
    const serverToken = "{{ .Server.Token }}";
    
    function showExtraModal(connectionString, type, currentExtra) {
      document.getElementById('extraConnectionString').value = connectionString;
      
      // Format the extra data for display
      let extraText = '';
      if (currentExtra && currentExtra !== 'null' && currentExtra !== null) {
        try {
          // If currentExtra is a Go map/object string, try to parse and format it
          let extraStr = String(currentExtra);
          
          // Handle Go map format like "map[key:value key2:value2]"
          if (extraStr.startsWith('map[') && extraStr.endsWith(']')) {
            // Convert Go map format to JSON
            let mapContent = extraStr.slice(4, -1); // Remove "map[" and "]"
            let jsonObj = {};
            
            // Simple parser for Go map format
            let parts = mapContent.split(' ');
            for (let part of parts) {
              if (part.includes(':')) {
                let [key, value] = part.split(':');
                jsonObj[key] = value;
              }
            }
            extraText = JSON.stringify(jsonObj, null, 2);
          } else {
            // Try to parse as JSON
            let extraObj = typeof currentExtra === 'string' ? JSON.parse(currentExtra) : currentExtra;
            extraText = JSON.stringify(extraObj, null, 2);
          }
        } catch (e) {
          // If parsing fails, convert the Go object to a readable format
          let extraStr = String(currentExtra);
          if (extraStr.startsWith('map[') && extraStr.endsWith(']')) {
            // Convert Go map format to JSON manually
            let mapContent = extraStr.slice(4, -1);
            let jsonObj = {};
            
            // Better parser for Go map format with more complex values
            let regex = /(\w+):([^\s]+)/g;
            let match;
            while ((match = regex.exec(mapContent)) !== null) {
              let key = match[1];
              let value = match[2];
              
              // Try to parse value as number or boolean
              if (value === 'true' || value === 'false') {
                jsonObj[key] = value === 'true';
              } else if (!isNaN(value)) {
                jsonObj[key] = Number(value);
              } else {
                jsonObj[key] = value;
              }
            }
            extraText = JSON.stringify(jsonObj, null, 2);
          } else {
            extraText = extraStr;
          }
        }
      }
      
      document.getElementById('extraData').value = extraText;
      document.getElementById('extraModal').classList.add('is-active');
    }

    function closeExtraModal() {
      document.getElementById('extraModal').classList.remove('is-active');
    }

    function saveExtra() {
      const connectionString = document.getElementById('extraConnectionString').value;
      const extraText = document.getElementById('extraData').value.trim();
      
      let extraData = null;
      if (extraText) {
        try {
          extraData = JSON.parse(extraText);
        } catch (e) {
          alert('Invalid JSON format. Please check your syntax.');
          return;
        }
      }

      // Send request to update RabbitMQ configuration
      const requestData = {
        connection_string: connectionString,
        extra: extraData
      };

      fetch('/rabbitmq?token=' + serverToken, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
        },
        body: JSON.stringify(requestData)
      })
      .then(response => response.json())
      .then(data => {
        if (data.success) {
          alert('Extra field updated successfully!');
          closeExtraModal();
          location.reload(); // Refresh to show changes
        } else {
          alert('Error updating extra field: ' + (data.message || 'Unknown error'));
        }
      })
      .catch(error => {
        console.error('Error:', error);
        alert('Network error occurred while updating extra field');
      });
    }

    // Functions for Add RabbitMQ Modal
    function showAddRabbitMQModal() {
      // Clear form
      document.getElementById('newConnectionString').value = '';
      document.getElementById('newTrackId').value = '';
      document.getElementById('newForwardInternal').checked = false;
      document.getElementById('newBroadcasts').checked = true; // Default to true
      document.getElementById('newGroups').checked = true; // Default to true
      document.getElementById('newDirect').checked = true; // Default to true
      document.getElementById('newReadReceipts').checked = false;
      document.getElementById('newCalls').checked = false;
      document.getElementById('newExtra').value = '';
      
      document.getElementById('addRabbitMQModal').classList.add('is-active');
    }

    function closeAddRabbitMQModal() {
      document.getElementById('addRabbitMQModal').classList.remove('is-active');
    }

    function saveNewRabbitMQ() {
      const connectionString = document.getElementById('newConnectionString').value.trim();
      const trackId = document.getElementById('newTrackId').value.trim();
      const forwardInternal = document.getElementById('newForwardInternal').checked;
      const broadcasts = document.getElementById('newBroadcasts').checked;
      const groups = document.getElementById('newGroups').checked;
      const direct = document.getElementById('newDirect').checked;
      const readReceipts = document.getElementById('newReadReceipts').checked;
      const calls = document.getElementById('newCalls').checked;
      const extraText = document.getElementById('newExtra').value.trim();

      // Validate required fields
      if (!connectionString) {
        alert('Connection string is required');
        return;
      }

      // Validate connection string format (basic validation)
      if (!connectionString.startsWith('amqp://') && !connectionString.startsWith('amqps://')) {
        alert('Please enter a valid AMQP connection string (should start with amqp:// or amqps://)');
        return;
      }

      // Validate extra JSON if provided
      let extraData = null;
      if (extraText) {
        try {
          extraData = JSON.parse(extraText);
        } catch (e) {
          alert('Invalid JSON format in Extra Data. Please check your syntax.');
          return;
        }
      }

      // Prepare request data
      const requestData = {
        connection_string: connectionString,
        trackid: trackId || '',
        forwardinternal: forwardInternal,
        broadcasts: broadcasts,
        groups: groups,
        direct: direct,
        readreceipts: readReceipts,
        calls: calls,
        extra: extraData
      };

      // Send request to add RabbitMQ configuration
      fetch('/rabbitmq?token=' + serverToken, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
        },
        body: JSON.stringify(requestData)
      })
      .then(response => response.json())
      .then(data => {
        if (data.success) {
          alert('RabbitMQ configuration added successfully!');
          closeAddRabbitMQModal();
          location.reload(); // Refresh to show changes
        } else {
          alert('Error adding RabbitMQ configuration: ' + (data.message || 'Unknown error'));
        }
      })
      .catch(error => {
        console.error('Error:', error);
        alert('Network error occurred while adding RabbitMQ configuration');
      });
    }
  </script>
{{ end }}
