{{ define "content" }}
  {{ $DOWNLOADPREFIX := .DownloadPrefix }}
  <link href="/assets/css/container-receive.css" rel="stylesheet">

  {{ if .ErrorMessage }}
  <div style="padding: 0 1.5rem;">
    <div class="notification is-warning is-light">
      <span class="icon"><i class="fas fa-exclamation-triangle"></i></span>
      {{ .ErrorMessage }}
    </div>
  </div>
  {{ end }}

  <div class="rx-header">
    <div class="rx-header-left">
      <h1 class="title is-4 mb-0">
        <span class="icon-text">
          <span class="icon rx-icon"><i class="fas fa-inbox"></i></span>
          <span>Messages</span>
        </span>
      </h1>
      <p class="rx-subtitle">
        <span class="tag is-light">{{ .Count }}</span>
        for <strong>{{ .Number }}</strong>
      </p>
    </div>
    <div class="rx-header-actions">
      <a class="button is-light is-small" href="/form/account">
        <span class="icon is-small"><i class="fas fa-arrow-left"></i></span>
        <span>Back</span>
      </a>
    </div>
  </div>

  <div class="rx-body">

    <!-- ── Filters ─────────────────────────────────────── -->
    <details class="rx-filters"{{ if or .SearchFilter .CategoryFilter .TypeFilter .ExceptionsFilter .FromMeFilter .FromHistoryFilter .ChatIDFilter .MessageIDFilter .TrackIDFilter .TimestampFilter .LastFilter }} open{{ end }}>
      <summary class="rx-filters-summary">
        <span class="rx-filters-chevron"><i class="fas fa-chevron-right"></i></span>
        <span class="rx-filters-title">Filters</span>
        <span class="rx-filters-tags">
          {{ if .SearchFilter }}<span class="tag is-info is-light is-small">search</span>{{ end }}
          {{ if .CategoryFilter }}<span class="tag is-info is-light is-small">{{ .CategoryFilter }}</span>{{ end }}
          {{ if .TypeFilter }}<span class="tag is-info is-light is-small">{{ .TypeFilter }}</span>{{ end }}
          {{ if .ExceptionsFilter }}<span class="tag is-warning is-light is-small">exceptions: {{ .ExceptionsFilter }}</span>{{ end }}
          {{ if .FromMeFilter }}<span class="tag is-info is-light is-small">fromme: {{ .FromMeFilter }}</span>{{ end }}
          {{ if .FromHistoryFilter }}<span class="tag is-info is-light is-small">history: {{ .FromHistoryFilter }}</span>{{ end }}
          {{ if .ChatIDFilter }}<span class="tag is-info is-light is-small">chat</span>{{ end }}
          {{ if .MessageIDFilter }}<span class="tag is-info is-light is-small">msg id</span>{{ end }}
          {{ if .TrackIDFilter }}<span class="tag is-info is-light is-small">track id</span>{{ end }}
          {{ if .TimestampFilter }}<span class="tag is-info is-light is-small">timestamp</span>{{ end }}
          {{ if .LastFilter }}<span class="tag is-info is-light is-small">last {{ .LastFilter }}m</span>{{ end }}
        </span>
      </summary>

      <form method="get" action="/form/server/{{ .Token }}/receive" class="rx-filters-body">

        <div class="field mb-3">
          <label class="label is-small" for="search">Search</label>
          <div class="control has-icons-left">
            <input id="search" class="input is-small" type="text" name="search"
              value="{{ .SearchFilter }}" placeholder="id, text, chat, participant, exceptions…">
            <span class="icon is-small is-left"><i class="fas fa-search"></i></span>
          </div>
        </div>

        <div class="rx-filters-grid">
          <div class="field">
            <label class="label is-small" for="category">Category</label>
            <div class="control">
              <div class="select is-small is-fullwidth">
                <select id="category" name="category">
                  <option value=""{{ if eq .CategoryFilter "" }} selected{{ end }}>All</option>
                  <option value="received"{{ if eq .CategoryFilter "received" }} selected{{ end }}>Received</option>
                  <option value="sent"{{ if eq .CategoryFilter "sent" }} selected{{ end }}>Sent</option>
                  <option value="sync"{{ if eq .CategoryFilter "sync" }} selected{{ end }}>Sync Events</option>
                  <option value="unhandled"{{ if eq .CategoryFilter "unhandled" }} selected{{ end }}>Unhandled</option>
                  <option value="events"{{ if eq .CategoryFilter "events" }} selected{{ end }}>All Events</option>
                </select>
              </div>
            </div>
          </div>

          <div class="field">
            <label class="label is-small" for="type">Type</label>
            <div class="control">
              <div class="select is-small is-fullwidth">
                <select id="type" name="type">
                  <option value=""{{ if eq .TypeFilter "" }} selected{{ end }}>All</option>
                  <option value="text"{{ if eq .TypeFilter "text" }} selected{{ end }}>text</option>
                  <option value="image"{{ if eq .TypeFilter "image" }} selected{{ end }}>image</option>
                  <option value="document"{{ if eq .TypeFilter "document" }} selected{{ end }}>document</option>
                  <option value="audio"{{ if eq .TypeFilter "audio" }} selected{{ end }}>audio</option>
                  <option value="video"{{ if eq .TypeFilter "video" }} selected{{ end }}>video</option>
                  <option value="location"{{ if eq .TypeFilter "location" }} selected{{ end }}>location</option>
                  <option value="contact"{{ if eq .TypeFilter "contact" }} selected{{ end }}>contact</option>
                  <option value="call"{{ if eq .TypeFilter "call" }} selected{{ end }}>call</option>
                  <option value="system"{{ if eq .TypeFilter "system" }} selected{{ end }}>system</option>
                  <option value="group"{{ if eq .TypeFilter "group" }} selected{{ end }}>group</option>
                  <option value="revoke"{{ if eq .TypeFilter "revoke" }} selected{{ end }}>revoke</option>
                  <option value="poll"{{ if eq .TypeFilter "poll" }} selected{{ end }}>poll</option>
                  <option value="view_once"{{ if eq .TypeFilter "view_once" }} selected{{ end }}>view_once</option>
                  <option value="sticker"{{ if eq .TypeFilter "sticker" }} selected{{ end }}>sticker</option>
                  <option value="unhandled"{{ if eq .TypeFilter "unhandled" }} selected{{ end }}>unhandled</option>
                </select>
              </div>
            </div>
          </div>

          <div class="field">
            <label class="label is-small" for="exceptions">Exceptions</label>
            <div class="control">
              <div class="select is-small is-fullwidth">
                <select id="exceptions" name="exceptions">
                  <option value=""{{ if eq .ExceptionsFilter "" }} selected{{ end }}>All</option>
                  <option value="true"{{ if eq .ExceptionsFilter "true" }} selected{{ end }}>Only Errors</option>
                  <option value="false"{{ if eq .ExceptionsFilter "false" }} selected{{ end }}>Without Errors</option>
                </select>
              </div>
            </div>
          </div>

          <div class="field">
            <label class="label is-small" for="fromme">From Me</label>
            <div class="control">
              <div class="select is-small is-fullwidth">
                <select id="fromme" name="fromme">
                  <option value=""{{ if eq .FromMeFilter "" }} selected{{ end }}>All</option>
                  <option value="true"{{ if eq .FromMeFilter "true" }} selected{{ end }}>Sent by me</option>
                  <option value="false"{{ if eq .FromMeFilter "false" }} selected{{ end }}>Received</option>
                </select>
              </div>
            </div>
          </div>

          <div class="field">
            <label class="label is-small" for="fromhistory">From History</label>
            <div class="control">
              <div class="select is-small is-fullwidth">
                <select id="fromhistory" name="fromhistory">
                  <option value=""{{ if eq .FromHistoryFilter "" }} selected{{ end }}>All</option>
                  <option value="true"{{ if eq .FromHistoryFilter "true" }} selected{{ end }}>true</option>
                  <option value="false"{{ if eq .FromHistoryFilter "false" }} selected{{ end }}>false</option>
                </select>
              </div>
            </div>
          </div>

          <div class="field">
            <label class="label is-small" for="chatid">Chat ID</label>
            <div class="control">
              <input id="chatid" class="input is-small" type="text" name="chatid"
                value="{{ .ChatIDFilter }}" placeholder="5511…@s.whatsapp.net">
            </div>
          </div>

          <div class="field">
            <label class="label is-small" for="messageid">Message ID</label>
            <div class="control">
              <input id="messageid" class="input is-small" type="text" name="messageid"
                value="{{ .MessageIDFilter }}" placeholder="ABCD…">
            </div>
          </div>

          <div class="field">
            <label class="label is-small" for="trackid">Track ID</label>
            <div class="control">
              <input id="trackid" class="input is-small" type="text" name="trackid"
                value="{{ .TrackIDFilter }}" placeholder="your-system-id">
            </div>
          </div>

          <div class="field">
            <label class="label is-small" for="timestamp">Timestamp</label>
            <div class="control">
              <input id="timestamp" class="input is-small" type="text" name="timestamp"
                value="{{ .TimestampFilter }}" placeholder="unix timestamp">
            </div>
          </div>

          <div class="field">
            <label class="label is-small" for="last">Last (minutes)</label>
            <div class="control">
              <input id="last" class="input is-small" type="text" name="last"
                value="{{ .LastFilter }}" placeholder="e.g. 60">
            </div>
          </div>
        </div>

        <div class="field is-grouped">
          <div class="control">
            <button type="submit" class="button is-info is-small">
              <span class="icon is-small"><i class="fas fa-filter"></i></span>
              <span>Apply</span>
            </button>
          </div>
          <div class="control">
            <a class="button is-light is-small" href="/form/server/{{ .Token }}/receive">
              <span class="icon is-small"><i class="fas fa-times"></i></span>
              <span>Clear</span>
            </a>
          </div>
        </div>

      </form>
    </details>

    <!-- ── Message list ────────────────────────────────── -->
    <div class="rx-list">
      {{ range .Messages }}
      <div class="rx-card{{ if .HasExceptions }} rx-card--error{{ end }}" id="msg-{{ .Id }}">

        <!-- Card header: meta row -->
        <div class="rx-card-head">
          <div class="rx-card-meta">

            <!-- Type badge -->
            <span class="rx-badge rx-type-{{ .Type }}">{{ .Type }}</span>

            <!-- Direction -->
            {{ if .FromMe }}
              <span class="rx-badge rx-sent" title="Sent by me">
                <i class="fas fa-arrow-right"></i> sent
              </span>
            {{ else }}
              <span class="rx-badge rx-received" title="Received">
                <i class="fas fa-arrow-left"></i> received
              </span>
            {{ end }}

            <!-- Status -->
            {{ if .HasStatus }}
              <span class="rx-badge rx-status">{{ .Status }}</span>
            {{ end }}

            <!-- Edited -->
            {{ if .Edited }}
              <span class="rx-badge rx-edited" title="Edited"><i class="fas fa-pen"></i> edited</span>
            {{ end }}

            <!-- FromHistory / FromAds -->
            {{ if .FromHistory }}
              <span class="rx-badge rx-history" title="From History"><i class="fas fa-history"></i> history</span>
            {{ end }}
            {{ if .FromAds }}
              <span class="rx-badge rx-ads" title="From Ads"><i class="fas fa-ad"></i> ads</span>
            {{ end }}


          </div>

          <div class="rx-card-ts" title="{{ .Id }}">
            <span class="rx-ts">{{ .Timestamp }}</span>
            <span class="rx-id">{{ .Id }}</span>
            {{ if .HasAttachment }}
              <a class="rx-badge rx-attachment{{ if not .Attachment.IsValidSize }} rx-attachment--invalid{{ end }}"
                download target="_blank"
                title="{{ .Attachment.Mimetype }}{{ if .Attachment.FileName }} · {{ .Attachment.FileName }}{{ end }} · {{ .Attachment.FileLength }} bytes"
                href="{{ $DOWNLOADPREFIX }}{{ .Id }}">
                <i class="fas fa-download"></i>
                {{ if .Attachment.FileName }}{{ .Attachment.FileName }}{{ else }}download{{ end }}
              </a>
            {{ end }}
          </div>
        </div>

        <!-- Card body: routing info + text -->
        <div class="rx-card-body">

          <!-- Chat -->
          <div class="rx-row">
            <span class="rx-lbl"><i class="fas fa-comments"></i></span>
            <span class="rx-val">
              <span class="rx-jid">{{ .Chat.Id }}</span>
              {{ if .Chat.Phone }}<span class="rx-phone">[{{ .Chat.Phone }}]</span>{{ end }}
              {{ if .Chat.LId }}<span class="rx-lid">LId: {{ .Chat.LId }}</span>{{ end }}
              {{ if .Chat.Title }}<span class="rx-title">{{ .Chat.Title }}</span>{{ end }}
            </span>
          </div>

          <!-- Participant -->
          {{ if .Participant }}
          <div class="rx-row">
            <span class="rx-lbl"><i class="fas fa-user"></i></span>
            <span class="rx-val">
              <span class="rx-jid">{{ .Participant.Id }}</span>
              {{ if .Participant.Phone }}<span class="rx-phone">[{{ .Participant.Phone }}]</span>{{ end }}
              {{ if .Participant.LId }}<span class="rx-lid">LId: {{ .Participant.LId }}</span>{{ end }}
              {{ if .Participant.Title }}<span class="rx-title">{{ .Participant.Title }}</span>{{ end }}
            </span>
          </div>
          {{ end }}

          <!-- TrackId -->
          {{ if .TrackId }}
          <div class="rx-row">
            <span class="rx-lbl"><i class="fas fa-tag"></i></span>
            <span class="rx-val rx-trackid">{{ .TrackId }}</span>
          </div>
          {{ end }}

          <!-- InReply -->
          {{ if .InReply }}
          <div class="rx-row">
            <span class="rx-lbl"><i class="fas fa-reply"></i></span>
            <span class="rx-val"><a class="rx-reply-link" href="#msg-{{ .InReply }}">{{ .InReply }}</a></span>
          </div>
          {{ end }}

          <!-- Text -->
          {{ if .Text }}
          <div class="rx-text">{{ .Text }}</div>
          {{ end }}

        </div>

        <!-- Dispatch errors -->
        {{ if .HasExceptions }}
        <div class="rx-errors">
          <div class="rx-errors-title">
            <i class="fas fa-exclamation-triangle"></i> Dispatch Errors
          </div>
          <ul class="rx-errors-list">
            {{ range .Exceptions }}
            <li>{{ . }}</li>
            {{ end }}
          </ul>
        </div>
        {{ end }}

        <!-- URL preview -->
        {{ if .Url }}
        <div class="rx-preview rx-preview--url">
          <div class="rx-preview-inner">
            {{ if .Url.Thumbnail }}
            <div class="rx-preview-thumb">
              <img src="{{ .Url.Thumbnail.GetThumbnailAsUrl|safeURL }}" alt="URL thumbnail">
            </div>
            {{ end }}
            <div class="rx-preview-info">
              <div class="rx-preview-badge"><i class="fas fa-link"></i> Link preview</div>
              {{ if .Url.Title }}<div class="rx-preview-title">{{ .Url.Title }}</div>{{ end }}
              {{ if .Url.Description }}<div class="rx-preview-desc">{{ .Url.Description }}</div>{{ end }}
              {{ if .Url.Reference }}<a class="rx-preview-ref" href="{{ .Url.Reference }}" target="_blank" rel="noopener">{{ .Url.Reference }}</a>{{ end }}
            </div>
          </div>
        </div>
        {{ end }}

        <!-- Attachment thumbnail -->
        {{ if .Attachment }}
          {{ if .Attachment.Thumbnail }}
          <div class="rx-preview rx-preview--attachment">
            <div class="rx-preview-inner">
              <div class="rx-preview-thumb">
                <img src="{{ .Attachment.Thumbnail.GetThumbnailAsUrl|safeURL }}" alt="Attachment preview">
              </div>
              <div class="rx-preview-info">
                <div class="rx-preview-badge"><i class="fas fa-paperclip"></i> Attachment preview</div>
                {{ if .Attachment.FileName }}<div class="rx-preview-title">{{ .Attachment.FileName }}</div>{{ end }}
                <div class="rx-preview-desc">{{ .Attachment.Mimetype }} &middot; {{ .Attachment.FileLength }} bytes</div>
              </div>
            </div>
          </div>
          {{ end }}
        {{ end }}

      </div>
      {{ end }}
    </div>

  </div>
{{ end }}
