{{ define "content" }}
<div class="min-h-screen bg-gradient-to-br from-gray-50 to-gray-100 flex items-center justify-center">
  <div class="max-w-2xl w-full mx-4">
    <div class="bg-white rounded-xl shadow-lg border border-gray-200 overflow-hidden">
      <div class="px-6 py-4 border-b border-gray-100 bg-red-50">
        <div class="flex items-center">
          <div class="w-12 h-12 bg-red-100 rounded-full flex items-center justify-center mr-4">
            <i class="fas fa-exclamation-triangle text-red-600 text-xl"></i>
          </div>
          <div>
            <h2 class="text-xl font-semibold text-red-900">Oops! Something went wrong</h2>
            <p class="text-red-700">{{ .Message }} [{{ .Status }} {{ .Code }}]</p>
          </div>
        </div>
      </div>
      
      <div class="p-6 space-y-4">
        {{ if .ErrorData }}
          <div>
            <h3 class="text-sm font-medium text-gray-700 mb-2">Error Details:</h3>
            <pre class="text-xs bg-gray-100 p-3 rounded border overflow-x-auto"><code>{{ .ErrorData }}</code></pre>
          </div>
        {{ end }}
        
        {{ if .Stack }}
          <div>
            <h3 class="text-sm font-medium text-gray-700 mb-2">Stack Trace:</h3>
            <pre class="text-xs bg-gray-100 p-3 rounded border overflow-x-auto max-h-64"><code>{{ .Stack }}</code></pre>
          </div>
        {{ end }}
      </div>
      
      <div class="px-6 py-4 border-t border-gray-100 bg-gray-50">
        <div class="flex justify-between items-center">
          <p class="text-sm text-gray-600">If this error persists, please contact support.</p>
          <a href="/form/account" class="inline-flex items-center px-4 py-2 bg-primary text-white rounded-lg hover:bg-opacity-90 transition-colors">
            <i class="fas fa-home mr-2"></i>Go to Dashboard
          </a>
        </div>
      </div>
    </div>
  </div>
</div>
{{ end }}
