{{ define "content" }}
<style>
  .setup-page {
    min-height: 100vh;
    background: var(--qp-bg);
    color: var(--qp-text);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 3rem 1rem 2rem;
  }
  .setup-wrapper {
    width: 100%;
    max-width: 420px;
  }
  .setup-brand {
    text-align: center;
    margin-bottom: 1.5rem;
  }
  .setup-brand img {
    width: 72px; height: 72px;
    border-radius: 50%;
    background: var(--qp-surface);
    padding: 8px;
    box-shadow: 0 2px 12px var(--qp-shadow-md);
  }
  .setup-brand .brand-title {
    font-size: 1.6rem; font-weight: 700; color: var(--qp-text); margin: 0.5rem 0 0;
  }
  .setup-brand .brand-sub { font-size: 0.85rem; color: var(--qp-text-muted); }
  .setup-card { border-radius: 12px; box-shadow: 0 4px 24px var(--qp-shadow-md); background: var(--qp-surface); overflow: hidden; }
  .setup-card-header {
    background: linear-gradient(135deg, #7C3AED 0%, #5B21B6 100%);
    padding: 1rem 1.5rem;
  }
  .setup-card-header p { color: rgba(255,255,255,0.9); font-size: 0.85rem; margin: 0; }
  .setup-card-body { padding: 1.75rem 2rem; background: var(--qp-surface); }
</style>

<div class="setup-page">
  <div class="setup-wrapper">

    <div class="setup-brand">
      <img src="/assets/favicon.png" alt="QuePasa logo">
      <p class="brand-title">QuePasa</p>
      <p class="brand-sub">WhatsApp bot management console</p>
    </div>

    <div class="setup-card">
      <div class="setup-card-header">
        <p>Create your admin account</p>
      </div>

      <div class="setup-card-body">
        <p class="is-size-7 has-text-danger mb-4">Development build &mdash; use with caution.</p>

        {{ if .ErrorMessage }}
        <div class="notification is-warning is-light mb-4" style="padding: 0.75rem 1rem;">
          <span class="icon"><i class="fas fa-exclamation-triangle"></i></span>
          {{ .ErrorMessage }}
        </div>
        {{ end }}

        <form method="post" action="/setup" novalidate>

          <div class="field">
            <label class="label is-sr-only" for="email">Email</label>
            <div class="control has-icons-left">
              <input
                id="email" name="email"
                class="input is-medium {{ if .EmailError }}is-danger{{ end }}"
                type="email" placeholder="Your email"
                value="{{ .Email }}" required
                autocomplete="username" aria-label="Email" autofocus>
              <span class="icon is-small is-left"><i class="fas fa-envelope"></i></span>
            </div>
            {{ if .UserExistsError }}
            <p class="help is-danger">This email is already taken.</p>
            {{ end }}
            {{ if .EmailInvalidError }}
            <p class="help is-danger">Please enter a valid email address.</p>
            {{ end }}
          </div>

          <div class="field">
            <label class="label is-sr-only" for="password">Password</label>
            <div class="control has-icons-left">
              <input
                id="password" name="password"
                class="input is-medium {{ if .PasswordStrengthError }}is-danger{{ end }}"
                type="password" placeholder="Your password"
                required autocomplete="new-password" aria-label="Password">
              <span class="icon is-small is-left"><i class="fas fa-lock"></i></span>
            </div>
            {{ if .PasswordStrengthError }}
            <p class="help is-danger">This password would take {{ .PasswordCrackTime }} to crack.</p>
            {{ end }}
          </div>

          <div class="field">
            <label class="label is-sr-only" for="passwordConfirm">Confirm password</label>
            <div class="control has-icons-left">
              <input
                id="passwordConfirm" name="passwordConfirm"
                class="input is-medium {{ if .PasswordMatchError }}is-danger{{ end }}"
                type="password" placeholder="Confirm password"
                required autocomplete="new-password"
                data-form-type="password-confirm" aria-label="Confirm password">
              <span class="icon is-small is-left"><i class="fas fa-lock"></i></span>
            </div>
            {{ if .PasswordMatchError }}
            <p class="help is-danger">Passwords do not match.</p>
            {{ end }}
          </div>

          <div class="field mt-5">
            <div class="control">
              <button type="submit" class="button is-primary is-medium is-fullwidth">
                <span class="icon"><i class="fas fa-user-plus"></i></span>
                <span>Create Admin User</span>
              </button>
            </div>
          </div>

          <div class="has-text-centered mt-3">
            <p class="is-size-7 has-text-grey">Already have an account? <a href="/login">Sign in</a></p>
          </div>

        </form>
      </div>
    </div>

    <p class="has-text-centered is-size-7 has-text-grey mt-4">Development build &mdash; use with caution.</p>
  </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
  const passwordField = document.getElementById('password');
  const confirmField  = document.getElementById('passwordConfirm');
  if (passwordField && confirmField) {
    passwordField.addEventListener('input', function() {
      if (this.value && !confirmField.value) confirmField.value = this.value;
    });
  }
});
</script>
{{ end }}
